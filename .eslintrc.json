{
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": "off",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "class-methods-use-this": "off",
    "import/extensions": ["error", "always", { "ignorePackages": true }]
  },
  "overrides": [
    {
      "files": ["migrations/**/*.js", "tests/**/*.js", "src/**/_test/**/*.js"],
      "rules": {
        "camelcase": "off"
      }
    }
  ]
}
